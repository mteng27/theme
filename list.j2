{% block style %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bree+Serif&family=Bungee+Shade&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ static_url }}ueno.css">
{% endblock %}

{% block body %}
  <div class="body">
    {% include "./_side.j2" %}
    <div class="main">
      <div class="inner main_mark">
        {% if page.type == 'tag' %}
          <section class="main_head">
            <h1>{{ page.topic.name }}</h1>
          </section>
        {% elif page.type == 'author' %}
          <section class="main_head author">
            {% set author = page.topic %}
            {% if author.avatar %}
              <a class="author_image" href="{{ linkify(author.url) }}">
                <img src="{{ author.avatar|thumbnail('ss') }}" alt="avatar" width="80" height="80">
              </a>
            {% endif %}
            <div class="author_info">
              <h1><a href="{{ linkify(author.url) }}">{{ author.name }}</a></h1>
            </div>
          </section>
        {% endif %}
        
        <ul class="simple-list">
          {% for subject in page.items %}
          <li>
            <time>{{ subject.published_at.strftime('%Y-%m-%d') }}</time>
            <a href="{{ linkify(subject.url) }}">{{ subject.title }}</a>
          </li>
          {% endfor %}
        </ul>
        
        {% if page.years %}
          <div class="navigation">
            {% for year in page.years|reverse %}
              {%- set url = page.base_url + year|string + '/' -%}
              <a{% if page.year == year %} class="active"{% endif %} href="{{ linkify(url) }}">{{ year }}</a>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
  {% include "./_foot.j2" %}
{% endblock %}